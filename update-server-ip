#!/bin/bash
###############################################################################
# update-server-ip.sh
# LiteSpeed Cache — Update Server IP across cPanel accounts
# Version : 2.0.0
# Location: /usr/local/sbin/update-server-ip.sh
# Usage   : bash /usr/local/sbin/update-server-ip.sh
# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG:
#   v2.0.0 | 2026-04-29 | เพิ่ม Mode 1/2 menu เลือก cPanel
#           |            | รองรับ 2 path structures
#           |            | กรอง domain ครบ (trueuserdomains+userdatadomains)
#           |            | Log fixed filename เขียนทับ (ไม่บวม)
#   v1.0.0 | 2026-04-01 | Initial release
###############################################################################

VERSION="2.0.0"

# ── Config ──────────────────────────────────────────────────────────────────
RAM_PER_JOB_MB=200
LOG_FILE="/var/log/lscwp-update-ip.log"
LOG_LOCK="/tmp/lscwp-log-$$.lock"
RESULT_DIR="/tmp/lscwp-results-$$"

# ── Colors ───────────────────────────────────────────────────────────────────
RED='\033[0;31m';   GREEN='\033[0;32m';  YELLOW='\033[1;33m'
CYAN='\033[0;36m';  WHITE='\033[1;37m';  BLUE='\033[0;34m'
BOLD='\033[1m';     DIM='\033[2m';       NC='\033[0m'

# ── Global Maps ───────────────────────────────────────────────────────────────
declare -A G_MAIN_DOMAINS=()
declare -A G_USER_MAINDOMAIN=()
declare -A G_ADDON_DOMAINS=()
declare -A G_DOMAIN_DOCROOT=()
declare -A G_PARKED_PARENT=()

# ── Cleanup ───────────────────────────────────────────────────────────────────
cleanup() { rm -rf "$RESULT_DIR"; rm -f "$LOG_LOCK"; }
trap cleanup EXIT
trap '
    echo ""
    echo -e "${YELLOW}  ยกเลิก — รอ jobs หยุด...${NC}"
    jobs -p | xargs -r kill 2>/dev/null
    wait 2>/dev/null
    exit 130
' INT TERM

mkdir -p "$RESULT_DIR"

# ── MAX_JOBS ─────────────────────────────────────────────────────────────────
CPU_CORES=$(nproc)
TOTAL_RAM_MB=$(free -m | awk '/^Mem:/{print $2}')
MAX_JOBS_BY_RAM=$(( TOTAL_RAM_MB / RAM_PER_JOB_MB ))
if [[ $CPU_CORES -lt $MAX_JOBS_BY_RAM ]]; then MAX_JOBS=$CPU_CORES
else MAX_JOBS=$MAX_JOBS_BY_RAM; fi
[[ $MAX_JOBS -lt 1  ]] && MAX_JOBS=1
[[ $MAX_JOBS -gt 20 ]] && MAX_JOBS=20

###############################################################################
# Logging
###############################################################################
log_init() {
    # เขียนทับทุกครั้ง (ไม่บวม)
    {
        printf '======================================\n'
        printf '  LiteSpeed Update Server IP v%s\n' "$VERSION"
        printf '======================================\n'
        printf '  Server  : %s\n' "$(hostname -s)"
        printf '  Started : %s\n' "$(TZ='Asia/Bangkok' date '+%Y-%m-%d %H:%M:%S')"
        printf '======================================\n\n'
    } > "$LOG_FILE"
}

log() {
    echo -e "$1"
    printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" \
        "$(echo -e "$1" | sed 's/\x1b\[[0-9;]*m//g')" \
        | flock "$LOG_LOCK" tee -a "$LOG_FILE" >/dev/null
}

###############################################################################
# Header
###############################################################################
print_header() {
    clear
    echo -e "${BLUE}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║  ${WHITE}${BOLD}LiteSpeed Update Server IP  v${VERSION}${NC}${BLUE}                     ║${NC}"
    echo -e "${BLUE}║  ${DIM}Server: $(hostname -s)  |  Max Jobs: ${MAX_JOBS}${NC}${BLUE}                    ║${NC}"
    echo -e "${BLUE}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

###############################################################################
# Build: Main Domains Map (/etc/trueuserdomains)
###############################################################################
build_main_domains_map() {
    G_MAIN_DOMAINS=(); G_USER_MAINDOMAIN=()
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        local domain cpuser
        domain=$(awk '{print $1}' <<< "$line" | tr -d ':' | tr -d ' \t')
        cpuser=$(awk '{print $2}' <<< "$line" | tr -d ' \t')
        [[ -z "$domain" || -z "$cpuser" ]] && continue
        G_MAIN_DOMAINS["$domain"]="$cpuser"
        G_USER_MAINDOMAIN["$cpuser"]="$domain"
    done < /etc/trueuserdomains
}

###############################################################################
# Build: Parked/Alias + Docroot Map (/etc/userdatadomains)
###############################################################################
build_parked_alias_map() {
    G_DOMAIN_DOCROOT=(); G_PARKED_PARENT=()
    [[ ! -f /etc/userdatadomains ]] && return
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        local domain rest cpuser parent dtype docroot
        domain=$(cut -d: -f1  <<< "$line" | tr -d ' \t')
        rest=$(cut   -d: -f2- <<< "$line")
        cpuser=$(awk  -F'==' '{print $1}' <<< "$rest" | tr -d ' \t')
        parent=$(awk  -F'==' '{print $2}' <<< "$rest" | tr -d ' \t')
        dtype=$(awk   -F'==' '{print $3}' <<< "$rest" | tr -d ' \t')
        docroot=$(awk -F'==' '{print $4}' <<< "$rest" | tr -d ' \t')
        [[ -z "$domain" || -z "$cpuser" ]] && continue
        [[ -n "$docroot" ]] && G_DOMAIN_DOCROOT["$domain"]="$docroot"
        if [[ "$dtype" == "parked" || "$dtype" == "alias" ]]; then
            [[ -n "$parent" ]] && G_PARKED_PARENT["$domain"]="$parent"
        fi
    done < /etc/userdatadomains
}

###############################################################################
# Get All cPanel Users
###############################################################################
get_all_cpanel_users() {
    local -n _out=$1
    _out=()
    local -A _seen=()
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" ]] && continue
        local u
        u=$(awk '{print $2}' <<< "$line" | tr -d ' \t')
        [[ -z "$u" ]] && continue
        [[ -z "${_seen[$u]+x}" ]] && _seen["$u"]=1 && _out+=("$u")
    done < /etc/trueuserdomains
    mapfile -t _out < <(printf '%s\n' "${_out[@]}" | sort)
}

###############################################################################
# Build: Addon Domains Map (/etc/userdomains)
# กรองออก: .cp, nobody, *, main domains, cPanel internal subdomains, parked/alias
###############################################################################
build_addon_domains_map() {
    local filter_users=("$@")
    G_ADDON_DOMAINS=()
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" ]] && continue
        [[ "$line" == *".cp:"*   ]] && continue
        [[ "$line" == *"nobody"* ]] && continue
        [[ "$line" == \**        ]] && continue
        local domain cpuser
        domain=$(awk '{print $1}' <<< "$line" | tr -d ':' | tr -d ' \t')
        cpuser=$(awk '{print $2}' <<< "$line" | tr -d ' \t')
        [[ -z "$domain" || -z "$cpuser" ]] && continue
        [[ "$domain" =~ ^(mail|ftp|cpanel|webmail|whm|cpcalendars|cpcontacts|autodiscover|www)\. ]] && continue
        [[ -n "${G_MAIN_DOMAINS[$domain]+x}" ]]  && continue
        [[ -n "${G_PARKED_PARENT[$domain]+x}" ]] && continue
        local main_dom="${G_USER_MAINDOMAIN[$cpuser]:-}"
        [[ -n "$main_dom" && "$domain" == *".$main_dom" ]] && continue
        if [[ ${#filter_users[@]} -gt 0 ]]; then
            local match=0
            for u in "${filter_users[@]}"; do [[ "$cpuser" == "$u" ]] && match=1 && break; done
            [[ $match -eq 0 ]] && continue
        fi
        G_ADDON_DOMAINS["$domain"]="$cpuser"
    done < /etc/userdomains
}

###############################################################################
# Find WP Path
# Priority: 1) userdatadomains docroot  2) /home/USER/public_html/DOMAIN/
#           3) /home/USER/DOMAIN/       4) whmapi1
###############################################################################
find_wp_path() {
    local domain=$1 cpuser=$2
    local -n _wpret=$3
    _wpret=""
    local home_dir
    home_dir=$(getent passwd "$cpuser" 2>/dev/null | cut -d: -f6)
    [[ -z "$home_dir" ]] && home_dir="/home/${cpuser}"

    local pre="${G_DOMAIN_DOCROOT[$domain]:-}"
    [[ -n "$pre" && -f "${pre}/wp-config.php" ]] && { _wpret="$pre"; return; }
    [[ -f "${home_dir}/public_html/${domain}/wp-config.php" ]] && { _wpret="${home_dir}/public_html/${domain}"; return; }
    [[ -f "${home_dir}/${domain}/wp-config.php" ]]             && { _wpret="${home_dir}/${domain}"; return; }

    local docroot
    docroot=$(whmapi1 --output=jsonpretty domainuserdata domain="$domain" 2>/dev/null \
        | python3 -c "
import sys,json
try:
    d=json.load(sys.stdin)
    print(d.get('data',{}).get('userdata',{}).get('documentroot',''))
except: print('')
" 2>/dev/null | tr -d ' ')
    [[ -n "$docroot" && -f "${docroot}/wp-config.php" ]] && _wpret="$docroot"
}

###############################################################################
# Worker — process_site
# Args: domain  cpuser  wp_path  server_ip  log_file  log_lock
#       result_dir  idx  total
###############################################################################
process_site() {
    local domain="$1" cpuser="$2" wp_path="$3" SERVER_IP="$4"
    local LOG_FILE="$5" LOG_LOCK="$6" RESULT_DIR="$7"
    local IDX="$8" TOTAL="$9"

    local RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[1;33m'
    local CYAN='\033[0;36m' BOLD='\033[1m' DIM='\033[2m' NC='\033[0m'

    local SITE="${cpuser}/${domain}"
    local UNIQUE="${IDX}_${BASHPID}"
    local PFX="${DIM}[${IDX}/${TOTAL}]${NC}"

    _log() {
        echo -e "$1"
        printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" \
            "$(echo -e "$1" | sed 's/\x1b\[[0-9;]*m//g')" \
            | flock "$LOG_LOCK" tee -a "$LOG_FILE" >/dev/null
    }
    _mark() { touch "${RESULT_DIR}/${1}_${UNIQUE}"; }
    _parse_ip() {
        grep -E "^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$" | head -1 | tr -d '[:space:]'
    }

    # ── Plugin ติดตั้งอยู่ไหม ────────────────────────────────────────────
    if ! wp --path="$wp_path" plugin is-installed litespeed-cache \
            --allow-root >/dev/null 2>&1; then
        _log "${PFX} ${YELLOW}⏭  SKIP${NC}  ${DIM}ไม่มี Plugin${NC}  ${CYAN}${SITE}${NC}"
        _mark "skip"; return
    fi

    # ── Plugin เปิดอยู่ไหม ───────────────────────────────────────────────
    if ! wp --path="$wp_path" plugin is-active litespeed-cache \
            --allow-root >/dev/null 2>&1; then
        _log "${PFX} ${YELLOW}⏭  SKIP${NC}  ${DIM}Plugin ถูกปิด${NC}  ${CYAN}${SITE}${NC}"
        _mark "skip"; return
    fi

    # ── อ่าน IP ปัจจุบัน ─────────────────────────────────────────────────
    local OLD_IP
    OLD_IP=$(wp --path="$wp_path" litespeed-option get server_ip \
        --allow-root 2>/dev/null | _parse_ip)

    # ── IP เหมือนเดิม → ข้าม ─────────────────────────────────────────────
    if [[ "$OLD_IP" == "$SERVER_IP" ]]; then
        _log "${PFX} ${DIM}⏩  SAME   IP ตรงกันแล้ว ข้าม${NC}  ${CYAN}${SITE}${NC}  ${DIM}(${OLD_IP})${NC}"
        _mark "same"; return
    fi

    # ── อัพเดต IP ────────────────────────────────────────────────────────
    if wp --path="$wp_path" litespeed-option set server_ip "$SERVER_IP" \
            --allow-root >/dev/null 2>&1; then
        local NEW_IP
        NEW_IP=$(wp --path="$wp_path" litespeed-option get server_ip \
            --allow-root 2>/dev/null | _parse_ip)
        if [[ "$NEW_IP" == "$SERVER_IP" ]]; then
            local OLD_D="${OLD_IP:-ว่าง}"
            _log "${PFX} ${GREEN}✅ OK${NC}     ${CYAN}${SITE}${NC}  ${DIM}${OLD_D} →${NC} ${GREEN}${NEW_IP}${NC}"
            _mark "success"
        else
            _log "${PFX} ${RED}❌ VERIFY${NC}  ${CYAN}${SITE}${NC}  ${DIM}(ได้ = ${NEW_IP:-ว่าง})${NC}"
            _mark "failed"
        fi
    else
        _log "${PFX} ${RED}❌ FAILED${NC}  ${CYAN}${SITE}${NC}"
        _mark "failed"
    fi
}

export -f process_site

###############################################################################
# Summary
###############################################################################
print_summary() {
    local total="$1"
    local ok same skip fail
    ok=$(  find "$RESULT_DIR" -name "success_*" 2>/dev/null | wc -l)
    same=$(find "$RESULT_DIR" -name "same_*"    2>/dev/null | wc -l)
    skip=$(find "$RESULT_DIR" -name "skip_*"    2>/dev/null | wc -l)
    fail=$(find "$RESULT_DIR" -name "failed_*"  2>/dev/null | wc -l)

    echo ""
    echo -e "${BLUE}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║  ${WHITE}${BOLD}SUMMARY${NC}${BLUE}                                                      ║${NC}"
    echo -e "${BLUE}╠══════════════════════════════════════════════════════════════╣${NC}"
    printf "${BLUE}║${NC}  ${GREEN}✅ อัพเดตสำเร็จ${NC}       : ${GREEN}%-4d${NC}%-28s${BLUE}║${NC}\n" "$ok"   ""
    printf "${BLUE}║${NC}  ${DIM}⏩  IP เดิม (ข้าม)${NC}    : %-4d%-28s${BLUE}║${NC}\n"               "$same" ""
    printf "${BLUE}║${NC}  ${YELLOW}⏭  ข้าม (ไม่มี/ปิด)${NC}  : ${YELLOW}%-4d${NC}%-28s${BLUE}║${NC}\n" "$skip" ""
    printf "${BLUE}║${NC}  ${RED}❌ ล้มเหลว${NC}             : ${RED}%-4d${NC}%-28s${BLUE}║${NC}\n"     "$fail" ""
    echo -e "${BLUE}╠══════════════════════════════════════════════════════════════╣${NC}"
    printf "${BLUE}║${NC}  รวมทั้งหมด             : %-4d%-28s${BLUE}║${NC}\n" "$total" ""
    echo -e "${BLUE}║${NC}  ${DIM}Log : ${LOG_FILE}${NC}"
    echo -e "${BLUE}╚══════════════════════════════════════════════════════════════╝${NC}"

    {
        printf '\n=== SUMMARY ===\n'
        printf 'OK     : %d\n' "$ok"
        printf 'Same   : %d\n' "$same"
        printf 'Skip   : %d\n' "$skip"
        printf 'Failed : %d\n' "$fail"
        printf 'Total  : %d\n' "$total"
        printf 'Done   : %s\n' "$(TZ='Asia/Bangkok' date '+%Y-%m-%d %H:%M:%S')"
    } >> "$LOG_FILE"
}

###############################################################################
# MAIN
###############################################################################

# Requirements
[[ $EUID -ne 0 ]] && { echo -e "${RED}[ERROR]${NC} กรุณารันด้วย root"; exit 1; }
command -v flock &>/dev/null || { echo -e "${RED}[ERROR]${NC} ไม่พบ flock"; exit 1; }
for f in /etc/userdomains /etc/trueuserdomains; do
    [[ ! -f "$f" ]] && { echo -e "${RED}[ERROR]${NC} ไม่พบ $f"; exit 1; }
done

print_header

# ── ดึง Server IP ────────────────────────────────────────────────────────
echo -e "  ${CYAN}กำลังดึง Server IP...${NC}"
SERVER_IP=""
for SOURCE in "https://ifconfig.me" "https://api.ipify.org" "https://ipinfo.io/ip"; do
    IP=$(curl -4 -s --max-time 10 "$SOURCE" 2>/dev/null | tr -d '[:space:]')
    if [[ "$IP" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
        SERVER_IP="$IP"; break
    fi
done
if [[ -z "$SERVER_IP" ]]; then
    echo -e "${RED}[ERROR]${NC} ดึง Server IP ไม่ได้"; exit 1
fi
echo -e "  ${GREEN}✔${NC}  Server IP : ${WHITE}${BOLD}${SERVER_IP}${NC}"
echo ""

# ── Menu ─────────────────────────────────────────────────────────────────
echo -e "${WHITE}${BOLD}เลือกโหมดการทำงาน:${NC}"
echo ""
echo -e "  ${CYAN}1.${NC}  อัพเดต ${WHITE}ทุกเว็บไซต์${NC} ในเซิร์ฟเวอร์นี้ทั้งหมด"
echo -e "  ${CYAN}2.${NC}  เลือกรันเฉพาะบาง ${WHITE}cPanel${NC} ในเซิร์ฟเวอร์นี้"
echo ""
printf "กรุณาเลือก [1-2]: "
read -r MODE

# ── Build maps ───────────────────────────────────────────────────────────
build_main_domains_map
build_parked_alias_map

declare -a ALL_CPANEL_USERS=()
get_all_cpanel_users ALL_CPANEL_USERS

case "$MODE" in
    # ──────────────────────────────────────────────────────────────────────
    1)
        print_header
        echo -e "${WHITE}${BOLD}[ Mode 1 ]  Update All — ทุก cPanel account${NC}"
        echo -e "  ${DIM}Server IP: ${SERVER_IP}${NC}"
        echo ""
        echo -e "${CYAN}cPanel accounts (${#ALL_CPANEL_USERS[@]} accounts):${NC}"
        echo ""
        for u in "${ALL_CPANEL_USERS[@]}"; do echo -e "  ${GREEN}•${NC}  $u"; done
        echo ""
        printf "${YELLOW}ยืนยันการอัพเดตทุก cPanel? [y/N]: ${NC}"
        read -r CONFIRM
        [[ "${CONFIRM,,}" != "y" ]] && echo -e "${RED}ยกเลิก${NC}" && exit 0
        build_addon_domains_map
        ;;

    # ──────────────────────────────────────────────────────────────────────
    2)
        print_header
        echo -e "${WHITE}${BOLD}[ Mode 2 ]  เลือก cPanel account${NC}"
        echo -e "  ${DIM}Server IP: ${SERVER_IP}${NC}"
        echo ""
        echo -e "${CYAN}cPanel accounts ที่มีในระบบ:${NC}"
        echo ""
        for i in "${!ALL_CPANEL_USERS[@]}"; do
            printf "  ${CYAN}%3d.${NC}  %s\n" "$(( i + 1 ))" "${ALL_CPANEL_USERS[$i]}"
        done
        echo ""
        echo -e "${YELLOW}เลือกหมายเลข (คั่นด้วย space หรือ comma)${NC}"
        echo -e "${DIM}เช่น:  1 3 5   หรือ   1,3,5${NC}"
        echo ""
        printf "เลือก: "
        read -r RAW_SEL

        declare -a SELECTED_USERS=()
        for sel in $(echo "$RAW_SEL" | tr ',' ' '); do
            if [[ "$sel" =~ ^[0-9]+$ ]]; then
                _idx=$(( sel - 1 ))
                if [[ $_idx -ge 0 && $_idx -lt ${#ALL_CPANEL_USERS[@]} ]]; then
                    SELECTED_USERS+=("${ALL_CPANEL_USERS[$_idx]}")
                else
                    echo -e "${RED}  [WARN]${NC} หมายเลข $sel ไม่มีใน list"
                fi
            else
                echo -e "${RED}  [WARN]${NC} '$sel' ไม่ใช่หมายเลข"
            fi
        done

        if [[ ${#SELECTED_USERS[@]} -eq 0 ]]; then
            echo -e "${RED}[ERROR]${NC} ไม่ได้เลือก cPanel ใด"; exit 1
        fi
        mapfile -t SELECTED_USERS < <(printf '%s\n' "${SELECTED_USERS[@]}" | sort -u)

        echo ""
        echo -e "${CYAN}cPanel ที่เลือก:${NC}"
        for u in "${SELECTED_USERS[@]}"; do echo -e "  ${GREEN}✔${NC}  $u"; done
        echo ""
        printf "${YELLOW}ยืนยัน? [y/N]: ${NC}"
        read -r CONFIRM2
        [[ "${CONFIRM2,,}" != "y" ]] && echo -e "${RED}ยกเลิก${NC}" && exit 0
        build_addon_domains_map "${SELECTED_USERS[@]}"
        ;;

    *)
        echo -e "${RED}[ERROR]${NC} กรุณาเลือก 1 หรือ 2"; exit 1
        ;;
esac

# ── SCAN: หา wp_path ────────────────────────────────────────────────────
echo ""
echo -e "${CYAN}  ⟳  กำลังสแกน domain...${NC}"

declare -a JOB_LIST=()
declare -a SCAN_SKIPS=()

for _domain in $(printf '%s\n' "${!G_ADDON_DOMAINS[@]}" | sort); do
    _cpu="${G_ADDON_DOMAINS[$_domain]}"
    _wpp=""
    find_wp_path "$_domain" "$_cpu" _wpp
    if [[ -z "$_wpp" ]]; then
        SCAN_SKIPS+=("$_domain|$_cpu")
    else
        JOB_LIST+=("${_domain}|${_cpu}|${_wpp}")
    fi
done

TOTAL=${#JOB_LIST[@]}

echo -e "  ${GREEN}✔${NC}  Domains : ${WHITE}${#G_ADDON_DOMAINS[@]}${NC}  (ไม่พบ wp: ${#SCAN_SKIPS[@]})"
echo ""

# ── Init log ─────────────────────────────────────────────────────────────
log_init
printf 'Server IP : %s\n' "$SERVER_IP"          >> "$LOG_FILE"
printf 'Total jobs: %d\n' "$TOTAL"              >> "$LOG_FILE"
printf 'Scan skip : %d\n' "${#SCAN_SKIPS[@]}"  >> "$LOG_FILE"
printf '\n'                                      >> "$LOG_FILE"

for _s in "${SCAN_SKIPS[@]}"; do
    IFS='|' read -r _d _c <<< "$_s"
    printf '[SCAN_SKIP] %s (%s) — ไม่พบ wp-config.php\n' "$_d" "$_c" >> "$LOG_FILE"
done

if [[ $TOTAL -eq 0 ]]; then
    echo -e "${YELLOW}  ไม่มี domain ที่จะประมวลผล${NC}"
    print_summary 0
    exit 0
fi

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "  ${DIM}Total: ${BOLD}${TOTAL}${NC} เว็บ  |  Max Jobs: ${BOLD}${MAX_JOBS}${NC}  |  IP: ${GREEN}${BOLD}${SERVER_IP}${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# ── DISPATCH ─────────────────────────────────────────────────────────────
declare -a PIDS=()
IDX=0

for entry in "${JOB_LIST[@]}"; do
    IFS='|' read -r domain cpuser wp_path <<< "$entry"
    (( IDX++ ))
    process_site "$domain" "$cpuser" "$wp_path" \
        "$SERVER_IP" "$LOG_FILE" "$LOG_LOCK" "$RESULT_DIR" \
        "$IDX" "$TOTAL" &
    PIDS+=($!)

    if [[ ${#PIDS[@]} -ge $MAX_JOBS ]]; then
        wait "${PIDS[0]}" 2>/dev/null
        PIDS=("${PIDS[@]:1}")
    fi
done

[[ ${#PIDS[@]} -gt 0 ]] && wait "${PIDS[@]}" 2>/dev/null

# ── SUMMARY ──────────────────────────────────────────────────────────────
print_summary "$TOTAL"
