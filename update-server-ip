#!/bin/bash

# ====================================
# Config
# ====================================
LOG_FILE="/var/log/lscwp-update-ip.log"
LOCK_FILE="${LOG_FILE}.lock"
RESULT_DIR="/tmp/lscwp-results-$$"
COUNTER_FILE="/tmp/lscwp-counter-$$"
RAM_PER_JOB_MB=200

# ====================================
# Colors
# ====================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ====================================
# Log function (Main Process)
# ====================================
log() {
    local DATE=$(date '+%Y-%m-%d %H:%M:%S')
    echo -e "$1"
    local CLEAN=$(echo -e "$1" | sed 's/\x1b\[[0-9;]*m//g')
    ( flock 200; echo "[$DATE] $CLEAN" >> "$LOG_FILE" ) 200>"$LOCK_FILE"
}

# ====================================
# Cleanup เมื่อ Script จบ
# ====================================
cleanup() {
    rm -rf "$RESULT_DIR"
    rm -f "$LOCK_FILE"
    rm -f "$COUNTER_FILE"
    rm -f "${COUNTER_FILE}.lock"
}
trap cleanup EXIT

# ====================================
# สร้าง Temp Dir เก็บผลลัพธ์
# ====================================
mkdir -p "$RESULT_DIR"
echo "0" > "$COUNTER_FILE"

# ====================================
# คำนวณ MAX_JOBS อัตโนมัติ
# ====================================
CPU_CORES=$(nproc)
TOTAL_RAM_MB=$(free -m | awk '/^Mem:/{print $2}')
MAX_JOBS_BY_RAM=$(( TOTAL_RAM_MB / RAM_PER_JOB_MB ))

if [ "$CPU_CORES" -lt "$MAX_JOBS_BY_RAM" ]; then
    MAX_JOBS=$CPU_CORES
else
    MAX_JOBS=$MAX_JOBS_BY_RAM
fi

[ "$MAX_JOBS" -lt 1 ] && MAX_JOBS=1
[ "$MAX_JOBS" -gt 20 ] && MAX_JOBS=20

# ====================================
# ดึง Server IP (ครั้งเดียว แล้วเก็บไว้ใช้ทั้งหมด)
# ====================================
log "${BOLD}======================================${NC}"
log "${BOLD} LITESPEED UPDATE SERVER IP${NC}"
log "${BOLD}======================================${NC}"
log " CPU Cores     : ${CYAN}${CPU_CORES} Core${NC}"
log " Total RAM     : ${CYAN}${TOTAL_RAM_MB} MB${NC}"
log " RAM/Job       : ${CYAN}${RAM_PER_JOB_MB} MB${NC}"
log " Auto MAX_JOBS : ${CYAN}${MAX_JOBS}${NC}"

log "${DIM}--------------------------------------${NC}"
log " กำลังดึง Server IP..."

SERVER_IP=""
for SOURCE in "https://ifconfig.me" "https://ipinfo.io/ip" "https://api.ipify.org"; do
    SERVER_IP=$(curl -s --max-time 10 "$SOURCE" 2>/dev/null | tr -d '[:space:]')
    if [[ "$SERVER_IP" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        break
    fi
    SERVER_IP=""
done

if [ -z "$SERVER_IP" ]; then
    log "${RED}❌ ERROR: ไม่สามารถดึง Server IP ได้ หยุดการทำงาน${NC}"
    exit 1
fi

log " Server IP     : ${BOLD}${GREEN}${SERVER_IP}${NC}  ${DIM}(เก็บค่าแล้ว ใช้ตลอด)${NC}"
log "${BOLD}======================================${NC}"

# ====================================
# ฟังก์ชันจัดการแต่ละเว็บ (Subprocess)
# ====================================
process_site() {
    local dir="$1"
    local SERVER_IP="$2"
    local LOG_FILE="$3"
    local LOCK_FILE="$4"
    local RESULT_DIR="$5"
    local TOTAL="$6"
    local COUNTER_FILE="$7"

    # แก้ไข: path /home/username/public_html/domain/ → field 3 = username, field 5 = domain
    local SITE
    SITE=$(echo "$dir" | awk -F'/' '{print $3"/"$5}')
    local UNIQUE="${BASHPID}_$(date +%s%N)"

    # Colors (ใช้ใน subprocess)
    local RED='\033[0;31m'
    local GREEN='\033[0;32m'
    local YELLOW='\033[1;33m'
    local CYAN='\033[0;36m'
    local BOLD='\033[1m'
    local DIM='\033[2m'
    local NC='\033[0m'

    _log() {
        local DATE=$(date '+%Y-%m-%d %H:%M:%S')
        echo -e "$1"
        local CLEAN=$(echo -e "$1" | sed 's/\x1b\[[0-9;]*m//g')
        ( flock 200; echo "[$DATE] $CLEAN" >> "$LOG_FILE" ) 200>"$LOCK_FILE"
    }

    # นับ counter (thread-safe)
    local NUM
    NUM=$(
        flock 201
        N=$(cat "$COUNTER_FILE")
        N=$(( N + 1 ))
        echo "$N" > "$COUNTER_FILE"
        echo "$N"
    ) 201>"${COUNTER_FILE}.lock"

    local PREFIX="${DIM}[${NUM}/${TOTAL}]${NC}"

    # ตรวจสอบว่าติดตั้ง LiteSpeed Cache ไหม
    if ! wp --path="$dir" plugin is-installed litespeed-cache --allow-root 2>/dev/null; then
        _log "${PREFIX} ${YELLOW}⏭  SKIP${NC}  ${DIM}(ไม่มี Plugin)${NC}  ${CYAN}${SITE}${NC}"
        touch "${RESULT_DIR}/skipped_${UNIQUE}"
        return
    fi

    # ตรวจสอบว่า Active ไหม
    if ! wp --path="$dir" plugin is-active litespeed-cache --allow-root 2>/dev/null; then
        _log "${PREFIX} ${YELLOW}⏭  SKIP${NC}  ${DIM}(Plugin ปิดอยู่)${NC}  ${CYAN}${SITE}${NC}"
        touch "${RESULT_DIR}/skipped_${UNIQUE}"
        return
    fi

    # แก้ไข: ใช้ wp litespeed-option get แทน wp option get litespeed.conf.server_ip
    local OLD_IP
    OLD_IP=$(wp --path="$dir" litespeed-option get server_ip --allow-root 2>/dev/null | tr -d '[:space:]')

    # ⭐ ข้าม: IP เหมือนเดิมแล้ว ไม่ต้องทำอะไร
    if [ "$OLD_IP" = "$SERVER_IP" ]; then
        _log "${PREFIX} ${DIM}⏩  SAME   (IP ตรงกันแล้ว)${NC}  ${CYAN}${SITE}${NC}  ${DIM}→ ${OLD_IP}${NC}"
        touch "${RESULT_DIR}/same_${UNIQUE}"
        return
    fi

    # อัพเดต IP
    if wp --path="$dir" litespeed-option set server_ip "$SERVER_IP" --allow-root 2>/dev/null; then
        # ตรวจสอบค่าที่บันทึกจริง
        local NEW_IP
        NEW_IP=$(wp --path="$dir" litespeed-option get server_ip --allow-root 2>/dev/null | tr -d '[:space:]')

        if [ "$NEW_IP" = "$SERVER_IP" ]; then
            local OLD_DISPLAY="${OLD_IP:-ว่าง}"
            _log "${PREFIX} ${GREEN}✅ OK${NC}     ${CYAN}${SITE}${NC}  ${DIM}${OLD_DISPLAY} → ${NC}${GREEN}${NEW_IP}${NC}"
            touch "${RESULT_DIR}/success_${UNIQUE}"
        else
            _log "${PREFIX} ${RED}❌ VERIFY${NC}  ${CYAN}${SITE}${NC}  ${DIM}(ค่าที่ได้ = ${NEW_IP:-ว่าง})${NC}"
            touch "${RESULT_DIR}/failed_${UNIQUE}"
        fi
    else
        _log "${PREFIX} ${RED}❌ FAILED${NC}  ${CYAN}${SITE}${NC}"
        touch "${RESULT_DIR}/failed_${UNIQUE}"
    fi
}

export -f process_site

# ====================================
# หา WordPress ทั้งหมด
# ====================================
DIRS=()
for dir in /home/*/public_html/*/; do
    if [ -f "${dir}wp-config.php" ]; then
        DIRS+=("$dir")
    fi
done

TOTAL=${#DIRS[@]}

if [ "$TOTAL" -eq 0 ]; then
    log "${RED}❌ ไม่พบ WordPress ใดๆ ใน /home/*/public_html/*/wp-config.php${NC}"
    exit 1
fi

log " พบ WordPress : ${BOLD}${TOTAL} เว็บ${NC}"
log " Server IP    : ${GREEN}${SERVER_IP}${NC}  ${DIM}(ใช้ค่านี้ทั้งหมด)${NC}"
log "${BOLD}======================================${NC}"

# ====================================
# Parallel Sliding Window
# ====================================
declare -a PIDS=()

for dir in "${DIRS[@]}"; do
    process_site "$dir" "$SERVER_IP" "$LOG_FILE" "$LOCK_FILE" "$RESULT_DIR" "$TOTAL" "$COUNTER_FILE" &
    PIDS+=($!)

    if [ "${#PIDS[@]}" -ge "$MAX_JOBS" ]; then
        wait "${PIDS[0]}"
        PIDS=("${PIDS[@]:1}")
    fi
done

# รอทุก Job เสร็จ
for pid in "${PIDS[@]}"; do
    wait "$pid"
done

# ====================================
# นับผลจาก Temp Files
# ====================================
SUCCESS=$(find "$RESULT_DIR" -name "success_*" 2>/dev/null | wc -l)
SKIPPED=$(find "$RESULT_DIR" -name "skipped_*" 2>/dev/null | wc -l)
SAME=$(find    "$RESULT_DIR" -name "same_*"    2>/dev/null | wc -l)
FAILED=$(find  "$RESULT_DIR" -name "failed_*"  2>/dev/null | wc -l)
CHANGED=$(( SUCCESS + FAILED ))

log "${BOLD}======================================${NC}"
log "${BOLD} สรุปผล${NC}"
log "${BOLD}--------------------------------------${NC}"
log " ${GREEN}✅ อัพเดตสำเร็จ${NC}     : ${BOLD}${SUCCESS}${NC} เว็บ"
log " ${DIM}⏩  IP เดิม (ข้าม)${NC}  : ${SAME} เว็บ"
log " ${YELLOW}⏭  ข้าม (ไม่มี/ปิด)${NC}: ${SKIPPED} เว็บ"
log " ${RED}❌ ล้มเหลว${NC}          : ${BOLD}${FAILED}${NC} เว็บ"
log "${BOLD}--------------------------------------${NC}"
log " รวมทั้งหมด          : ${TOTAL} เว็บ"
log " Log อยู่ที่          : ${DIM}${LOG_FILE}${NC}"
log "${BOLD}======================================${NC}"
