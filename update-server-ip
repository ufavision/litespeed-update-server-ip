#!/bin/bash
# ==========================================================
#  LiteSpeed Cache — Update Server IP
#  รันด้วย: bash <(curl -s URL)
# ==========================================================

# ---------- Config ----------
LOG_FILE="/var/log/lscwp-update-ip.log"
LOG_LOCK="/tmp/lscwp-log-$$.lock"
RESULT_DIR="/tmp/lscwp-$$"
RAM_PER_JOB_MB=150

# ---------- Colors ----------
R='\033[0;31m'   # Red
G='\033[0;32m'   # Green
Y='\033[1;33m'   # Yellow
C='\033[0;36m'   # Cyan
B='\033[1m'      # Bold
D='\033[2m'      # Dim
N='\033[0m'      # Reset

# ---------- Logging ----------
log() {
    echo -e "$1"
    printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" \
        "$(echo -e "$1" | sed 's/\x1b\[[0-9;]*m//g')" \
        | flock "$LOG_LOCK" tee -a "$LOG_FILE" >/dev/null
}

# ---------- Cleanup ----------
cleanup() { rm -rf "$RESULT_DIR" "$LOG_LOCK"; }
trap cleanup EXIT

mkdir -p "$RESULT_DIR"

# ==========================================================
#  MAX_JOBS — คำนวณจาก CPU + RAM
# ==========================================================
CPU=$(nproc)
RAM_MB=$(awk '/^MemTotal/{printf "%d", $2/1024}' /proc/meminfo)
BY_RAM=$(( RAM_MB / RAM_PER_JOB_MB ))
MAX_JOBS=$(( CPU < BY_RAM ? CPU : BY_RAM ))
(( MAX_JOBS < 1  )) && MAX_JOBS=1
(( MAX_JOBS > 20 )) && MAX_JOBS=20

# ==========================================================
#  Header
# ==========================================================
log ""
log "${B}╔══════════════════════════════════════╗${N}"
log "${B}║   LITESPEED  UPDATE  SERVER  IP      ║${N}"
log "${B}╚══════════════════════════════════════╝${N}"
log " ${D}CPU Cores  :${N} ${C}${CPU}${N}"
log " ${D}Total RAM  :${N} ${C}${RAM_MB} MB${N}"
log " ${D}Max Jobs   :${N} ${C}${MAX_JOBS}${N}"
log "${D}────────────────────────────────────────${N}"

# ==========================================================
#  ดึง Server IP — fallback 3 แหล่ง, เก็บใน $SERVER_IP
# ==========================================================
log " ${D}กำลังดึง Server IP...${N}"

SERVER_IP=""
for URL in "https://ifconfig.me" "https://api.ipify.org" "https://ipinfo.io/ip"; do
    IP=$(curl -4 -s --max-time 8 "$URL" 2>/dev/null | tr -d '[:space:]')
    if [[ $IP =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
        SERVER_IP="$IP"
        break
    fi
done

if [[ -z "$SERVER_IP" ]]; then
    log " ${R}❌  ERROR: ดึง Server IP ไม่ได้ — หยุดทำงาน${N}"
    exit 1
fi

log " ${D}Server IP  :${N} ${B}${G}${SERVER_IP}${N}  ${D}← ใช้ค่านี้กับทุกเว็บ${N}"

# ==========================================================
#  หา WordPress ทั้งหมด
# ==========================================================
log "${D}────────────────────────────────────────${N}"
log " ${D}กำลังค้นหา WordPress...${N}"

mapfile -t DIRS < <(find /home/*/public_html/*/ -maxdepth 0 -type d 2>/dev/null \
    | while read -r d; do [[ -f "$d/wp-config.php" ]] && echo "$d"; done)

TOTAL=${#DIRS[@]}

if (( TOTAL == 0 )); then
    log " ${R}❌  ไม่พบ WordPress ใดๆ${N}"
    exit 1
fi

log " ${D}พบ WordPress :${N} ${B}${TOTAL} เว็บ${N}"
log "${D}────────────────────────────────────────${N}"

# ==========================================================
#  Worker function — รันใน subprocess
# ==========================================================
run_site() {
    local dir="$1"
    local idx="$2"
    local total="$3"
    local srv_ip="$4"
    local result_dir="$5"
    local log_file="$6"
    local log_lock="$7"

    local R='\033[0;31m' G='\033[0;32m' Y='\033[1;33m'
    local C='\033[0;36m' B='\033[1m' D='\033[2m' N='\033[0m'

    # ชื่อเว็บจาก path /home/USER/public_html/DOMAIN/
    local site
    site=$(awk -F'/' '{print $3"/"$5}' <<< "$dir")
    local pfx="${D}[${idx}/${total}]${N}"

    _log() {
        echo -e "$1"
        printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" \
            "$(echo -e "$1" | sed 's/\x1b\[[0-9;]*m//g')" \
            | flock "$log_lock" tee -a "$log_file" >/dev/null
    }

    _mark() { touch "${result_dir}/${1}_$$_${idx}"; }

    # --- ตรวจ Plugin ติดตั้งหรือไม่ ---
    if ! wp --path="$dir" plugin is-installed litespeed-cache --allow-root 2>/dev/null; then
        _log "${pfx} ${Y}⏭  SKIP${N}  ${D}ไม่มี Plugin${N}  ${C}${site}${N}"
        _mark "skip"; return
    fi

    # --- ตรวจ Plugin เปิดอยู่ไหม ---
    if ! wp --path="$dir" plugin is-active litespeed-cache --allow-root 2>/dev/null; then
        _log "${pfx} ${Y}⏭  SKIP${N}  ${D}Plugin ถูกปิด${N}  ${C}${site}${N}"
        _mark "skip"; return
    fi

    # --- อ่านค่า IP ปัจจุบัน ---
    local old_ip
    old_ip=$(wp --path="$dir" litespeed-option get server_ip \
        --allow-root 2>/dev/null | tr -d '[:space:]')

    # --- IP เหมือนเดิม → ข้าม ---
    if [[ "$old_ip" == "$srv_ip" ]]; then
        _log "${pfx} ${D}⏩  SAME${N}   ${D}IP ตรงกันแล้ว${N}  ${C}${site}${N}  ${D}(${old_ip})${N}"
        _mark "same"; return
    fi

    # --- อัพเดต IP ---
    if wp --path="$dir" litespeed-option set server_ip "$srv_ip" \
            --allow-root 2>/dev/null; then

        # ยืนยันค่าที่เขียน
        local new_ip
        new_ip=$(wp --path="$dir" litespeed-option get server_ip \
            --allow-root 2>/dev/null | tr -d '[:space:]')

        if [[ "$new_ip" == "$srv_ip" ]]; then
            local old_show="${old_ip:-ว่าง}"
            _log "${pfx} ${G}✅  OK${N}     ${C}${site}${N}  ${D}${old_show} →${N} ${G}${new_ip}${N}"
            _mark "ok"
        else
            _log "${pfx} ${R}❌  VERIFY${N}  ${C}${site}${N}  ${D}ค่าที่ได้ = ${new_ip:-ว่าง}${N}"
            _mark "fail"
        fi
    else
        _log "${pfx} ${R}❌  FAIL${N}    ${C}${site}${N}"
        _mark "fail"
    fi
}

export -f run_site

# ==========================================================
#  Parallel — Sliding Window
# ==========================================================
declare -a PIDS=()
IDX=0

for dir in "${DIRS[@]}"; do
    (( IDX++ ))
    run_site "$dir" "$IDX" "$TOTAL" "$SERVER_IP" \
             "$RESULT_DIR" "$LOG_FILE" "$LOG_LOCK" &
    PIDS+=($!)

    if (( ${#PIDS[@]} >= MAX_JOBS )); then
        wait "${PIDS[0]}"
        PIDS=("${PIDS[@]:1}")
    fi
done

# รอทุก Job
for pid in "${PIDS[@]}"; do wait "$pid"; done

# ==========================================================
#  สรุปผล
# ==========================================================
CNT_OK=$(find   "$RESULT_DIR" -name "ok_*"   2>/dev/null | wc -l)
CNT_SAME=$(find "$RESULT_DIR" -name "same_*" 2>/dev/null | wc -l)
CNT_SKIP=$(find "$RESULT_DIR" -name "skip_*" 2>/dev/null | wc -l)
CNT_FAIL=$(find "$RESULT_DIR" -name "fail_*" 2>/dev/null | wc -l)

log ""
log "${B}╔══════════════════════════════════════╗${N}"
log "${B}║              สรุปผล                  ║${N}"
log "${B}╚══════════════════════════════════════╝${N}"
log " ${G}✅  อัพเดตสำเร็จ${N}       : ${B}${CNT_OK}${N} เว็บ"
log " ${D}⏩  IP เดิม (ข้าม)${N}    : ${CNT_SAME} เว็บ"
log " ${Y}⏭  ข้าม (ไม่มี/ปิด)${N} : ${CNT_SKIP} เว็บ"
log " ${R}❌  ล้มเหลว${N}            : ${B}${CNT_FAIL}${N} เว็บ"
log "${D}────────────────────────────────────────${N}"
log " รวมทั้งหมด            : ${B}${TOTAL}${N} เว็บ"
log " Log                   : ${D}${LOG_FILE}${N}"
log "${B}════════════════════════════════════════${N}"
log ""
